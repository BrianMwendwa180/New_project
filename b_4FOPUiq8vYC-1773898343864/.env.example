# PayPal Configuration
# Get Sandbox credentials from: https://developer.paypal.com/dashboard/applications/create
# 1. Log in → My Apps & Credentials → Create App (Sandbox)
# 2. Copy Client ID and Secret below
# 3. For production: Create Live App, use LIVE_CLIENT_ID/LIVE_SECRET

# Required for server verification
PAYPAL_CLIENT_ID=sb-YOUR_SANDBOX_CLIENT_ID_HERE
PAYPAL_CLIENT_SECRET=your_sandbox_app_secret_here

# Optional: Client-side fallback (not recommended for prod)
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=sb-YOUR_SANDBOX_CLIENT_ID_HERE

# Production (uncomment when ready)
# LIVE_CLIENT_ID=your_live_client_id_here
# LIVE_CLIENT_SECRET=your_live_app_secret_here

# Usage:
# 1. Copy this to .env.local
# 2. Replace placeholders with real values
# 3. Go to /admin → Update Client ID (for buttons)
# 4. Restart dev server: pnpm dev
# 5. Test payment!

# Note: Never commit .env.local to git!
